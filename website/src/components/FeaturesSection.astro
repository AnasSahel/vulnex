---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const freeFeatures = [
  'Multi-source CVE enrichment (NVD, KEV, EPSS, GHSA, OSV)',
  'P0\u2013P4 risk scoring with configurable weights',
  'Lockfile scanning (go.sum, package-lock, yarn, pnpm, Cargo, Gemfile, and more)',
  'CycloneDX / SPDX SBOM scanning and diffing',
  'Exploit tracking (GitHub PoC, Nuclei, Metasploit, ExploitDB)',
  'Watch lists with temporal change detection',
  'Offline mode with local SQLite cache',
  'SARIF, JSON, CSV, Markdown output formats',
  'Pipe-friendly stdin support and composable commands',
  '.vulnexignore suppression with expiry and audit trails',
];

const proFeatures = [
  'Web dashboard with risk posture overview',
  'Team watch lists and shared vulnerability tracking',
  'Slack, email, and webhook alert notifications',
  'Scheduled daily scans and continuous monitoring',
  'EPSS trend visualization and historical analytics',
  'REST API for custom integrations',
  'Role-based access control',
  'Audit log and compliance reporting',
  'Priority support',
  'SSO / SAML authentication',
];
---

<section id="features">
  <div class="container reveal">
    <div class="section-header">
      <span class="section-label">FEATURES</span>
      <h2 class="section-title">Free CLI. Pro platform.</h2>
      <p class="section-desc">The open-source CLI gives you everything for individual use. The cloud platform adds team collaboration and continuous monitoring.</p>
    </div>

    <div class="features-columns">
      <div class="feature-col">
        <div class="col-header">
          <span class="col-badge free">Free</span>
          <h3>CLI</h3>
          <p>Open source, runs locally</p>
        </div>
        <ul>
          {freeFeatures.map(f => (
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={`${base}/docs/`} class="col-link">Explore docs &rarr;</a>
      </div>

      <div class="feature-col pro">
        <div class="col-header">
          <span class="col-badge pro-badge">Pro</span>
          <h3>Cloud Platform</h3>
          <p>Coming soon &mdash; join the waitlist</p>
        </div>
        <ul>
          {proFeatures.map(f => (
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href="#platform" class="col-link">Join waitlist &rarr;</a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 72px 24px;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 580px;
    margin: 0 auto;
  }

  /* Two-column layout */
  .features-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .feature-col {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
  }

  .feature-col.pro {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--border));
  }

  .col-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .col-badge {
    display: inline-block;
    padding: 3px 12px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 4px;
    margin-bottom: 12px;
  }

  .col-badge.free {
    color: var(--green);
    background: color-mix(in srgb, var(--green) 12%, transparent);
  }

  .col-badge.pro-badge {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .col-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .col-header p {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  /* Feature list */
  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  li svg {
    flex-shrink: 0;
    color: var(--green);
    margin-top: 2px;
  }

  .pro li svg {
    color: var(--accent);
  }

  .col-link {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .col-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .features-columns {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 56px 16px;
    }

    .feature-col {
      padding: 24px;
    }
  }
</style>
