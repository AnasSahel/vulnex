---
import FeatureCard from './FeatureCard.astro';
import { features } from '../content/features';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="features">
  <div class="container reveal">
      <span class="section-label">FEATURES</span>
      <h2 class="section-title">Everything you need in one query</h2>
      <p class="section-desc">Combine five vulnerability data sources, score risk, scan SBOMs, and pipe results — all from a single static binary.</p>
      <a href={`${base}/docs/cve/`} class="section-link">Explore command reference &rarr;</a>
    <div style="margin-bottom: 48px;"></div>
    <div class="features-grid">
      {features.map((f, i) => (
        <div class:list={[{ 'featured': i < 3 }]}>
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 96px 24px;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
  }

  .section-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .section-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .section-link:hover {
    text-decoration: underline;
  }

  .features-grid {
    text-align: left;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .features-grid :global(.featured) {
    grid-column: span 1;
  }

  .features-grid :global(.featured .feature-card) {
    padding: 28px 26px;
  }

  .features-grid :global(.featured h3) {
    font-size: 1.1rem;
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-grid :global(.featured) {
      grid-column: span 1;
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 64px 16px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 1.5rem;
    }
  }
</style>
