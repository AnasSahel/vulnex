---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="footer">
  <div class="footer-fade" aria-hidden="true"></div>
  <div class="container">
    <div class="footer-bottom">
      <div class="footer-brand">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor">
          <circle cx="11" cy="11" r="3.5"/>
          <circle cx="21" cy="11" r="3.5"/>
          <circle cx="11" cy="21" r="3.5"/>
          <circle cx="24" cy="18" r="3.5" opacity="0.5"/>
        </svg>
        <span>vulnex</span>
      </div>

      <div class="footer-links">
        <a href={`${base}/docs/`}>Docs</a>
        <a href={`${base}/blog/`}>Blog</a>
        <a href="https://github.com/AnasSahel/vulnex">GitHub</a>
        <a href="https://github.com/AnasSahel/vulnex/releases">Releases</a>
        <a href="https://github.com/AnasSahel/vulnex/blob/main/LICENSE">MIT License</a>
      </div>

      <p class="footer-credit">Built by <a href="https://github.com/AnasSahel">Anas Sahel</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 48px 24px 40px;
    background: var(--bg-secondary);
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .footer-fade {
    position: absolute;
    top: -48px;
    left: 0;
    right: 0;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--bg-secondary));
    pointer-events: none;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
  }

  .footer-brand svg {
    color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 16px;
  }

  .footer-links a {
    color: var(--text-secondary);
    transition: color 0.15s;
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .footer-credit a {
    color: var(--accent);
  }
</style>
