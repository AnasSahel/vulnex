---
import TabbedPanel from './TabbedPanel.astro';
import TerminalWindow from './TerminalWindow.astro';
import { installMethods } from '../content/install';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="install">
  <div class="container install-split reveal">
    <div class="install-text">
      <span class="section-label">INSTALLATION</span>
      <h2 class="section-title">Get started in seconds</h2>
      <p class="section-desc">Pick your preferred method — one command and you're ready.</p>
      <a href={`${base}/docs/getting-started/`} class="section-link">Post-install quickstart &rarr;</a>
    </div>

    <div class="install-wrap">
      <TabbedPanel tabs={installMethods.map(m => ({ id: m.id, label: m.label }))} groupId="install">
        {installMethods.map((m, i) => (
          <div data-tab-id={m.id} class:list={[{ active: i === 0 }]}>
            <div class="install-code">
              <TerminalWindow>
                <div class="code-row">
                  <pre>{m.code}</pre>
                  <button class="copy-btn" data-copy={m.code} aria-label="Copy to clipboard">
                    <svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                    <svg class="icon-check" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </button>
                </div>
              </TerminalWindow>
            </div>
          </div>
        ))}
      </TabbedPanel>
    </div>
  </div>
</section>

<style>
  section {
    padding: 96px 24px;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
  }

  .install-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    align-items: center;
  }

  .install-text {
    text-align: left;
  }

  .section-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 600px;
  }

  .section-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .section-link:hover {
    text-decoration: underline;
  }

  .install-wrap {
    max-width: 100%;
  }

  .install-code :global(.terminal-window) {
    border-radius: 0 0 var(--radius) var(--radius);
    border-top: none;
  }

  .code-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }

  .code-row pre {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    white-space: pre;
    overflow-x: auto;
  }

  .copy-btn {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }

  .copy-btn:hover {
    color: var(--text);
    background: var(--border);
  }

  .copy-btn .icon-check {
    display: none;
    color: var(--green);
  }

  .copy-btn.copied .icon-copy { display: none; }
  .copy-btn.copied .icon-check { display: block; }

  @media (max-width: 768px) {
    .install-split {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .install-text {
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 64px 16px;
    }

    .section-title {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 2000);
    });
  });
</script>
