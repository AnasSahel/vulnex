---
import { getDocsSections } from '../content/docs-helpers';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build flat search index at build time (from content collection)
const docsSections = await getDocsSections();
const searchEntries: { title: string; description: string; href: string; section: string }[] = [];

for (const section of docsSections) {
  for (const page of section.pages) {
    searchEntries.push({
      title: page.title,
      description: page.description,
      href: `${base}/docs/${page.slug}/`,
      section: section.label,
    });
    if (page.subcommands) {
      for (const sub of page.subcommands) {
        searchEntries.push({
          title: sub.label,
          description: `${page.title} subcommand`,
          href: `${base}/docs/${page.slug}/#${sub.id}`,
          section: section.label,
        });
      }
    }
  }
}
---

<div class="search-backdrop" id="search-backdrop"></div>
<div class="search-dialog" id="search-dialog" role="dialog" aria-label="Search documentation">
  <div class="search-header">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input
      type="text"
      id="search-input"
      class="search-input"
      placeholder="Search documentation..."
      autocomplete="off"
      autofocus
    />
    <kbd class="search-kbd">Esc</kbd>
  </div>
  <div class="search-results" id="search-results"></div>
</div>

<script define:vars={{ searchEntries }}>
  const backdrop = document.getElementById('search-backdrop');
  const dialog = document.getElementById('search-dialog');
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');
  let activeIdx = 0;
  let currentResults = [];

  function open() {
    backdrop.classList.add('open');
    dialog.classList.add('open');
    input.value = '';
    input.focus();
    render(searchEntries);
  }

  function close() {
    backdrop.classList.remove('open');
    dialog.classList.remove('open');
  }

  function navigate(href) {
    close();
    window.location.href = href;
  }

  function createResultEl(entry, idx, query) {
    const a = document.createElement('a');
    a.href = entry.href;
    a.className = 'search-result' + (idx === 0 ? ' active' : '');
    a.dataset.idx = idx;

    const titleSpan = document.createElement('span');
    titleSpan.className = 'search-result-title';
    titleSpan.textContent = entry.title;

    const sectionSpan = document.createElement('span');
    sectionSpan.className = 'search-result-section';
    sectionSpan.textContent = entry.section;

    const descSpan = document.createElement('span');
    descSpan.className = 'search-result-desc';
    descSpan.textContent = entry.description;

    a.appendChild(titleSpan);
    a.appendChild(sectionSpan);
    a.appendChild(descSpan);

    a.addEventListener('click', (e) => {
      e.preventDefault();
      navigate(entry.href);
    });
    a.addEventListener('mouseenter', () => {
      setActive(idx);
    });

    return a;
  }

  function render(results) {
    currentResults = results;
    activeIdx = 0;

    while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);

    if (results.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'search-empty';
      empty.textContent = 'No results found';
      resultsEl.appendChild(empty);
      return;
    }

    results.forEach((entry, i) => {
      resultsEl.appendChild(createResultEl(entry, i, input.value));
    });
  }

  function setActive(idx) {
    activeIdx = idx;
    resultsEl.querySelectorAll('.search-result').forEach((el, i) => {
      el.classList.toggle('active', i === idx);
    });
    const activeEl = resultsEl.querySelector('.search-result.active');
    if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
  }

  function filter(query) {
    if (!query) { render(searchEntries); return; }
    const q = query.toLowerCase();
    const results = searchEntries.filter(e =>
      e.title.toLowerCase().includes(q) ||
      e.description.toLowerCase().includes(q)
    );
    render(results);
  }

  // Keyboard shortcut: Cmd+K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (dialog.classList.contains('open')) close();
      else open();
    }
    if (e.key === 'Escape' && dialog.classList.contains('open')) {
      e.preventDefault();
      close();
    }
  });

  // Input filtering
  input.addEventListener('input', () => {
    filter(input.value);
  });

  // Arrow keys + Enter inside dialog
  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (activeIdx < currentResults.length - 1) setActive(activeIdx + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (activeIdx > 0) setActive(activeIdx - 1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (currentResults[activeIdx]) navigate(currentResults[activeIdx].href);
    }
  });

  // Close on backdrop click
  backdrop.addEventListener('click', close);

  // Expose open for the navbar trigger
  window.__openSearch = open;
</script>

<style>
  .search-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 200;
  }

  .search-backdrop.open {
    display: block;
  }

  .search-dialog {
    display: none;
    position: fixed;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 560px;
    max-width: calc(100vw - 32px);
    max-height: 480px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2);
    z-index: 201;
    overflow: hidden;
    flex-direction: column;
  }

  .search-dialog.open {
    display: flex;
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }

  .search-icon {
    flex-shrink: 0;
    color: var(--text-secondary);
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 0.95rem;
    color: var(--text);
    font-family: inherit;
  }

  .search-input::placeholder {
    color: var(--text-secondary);
    opacity: 0.6;
  }

  .search-kbd {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    padding: 2px 6px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-secondary);
    background: var(--surface);
    flex-shrink: 0;
  }

  .search-results {
    overflow-y: auto;
    max-height: 380px;
    padding: 8px;
  }

  .search-results :global(.search-result) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 4px 12px;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    cursor: pointer;
    transition: background 0.1s;
  }

  .search-results :global(.search-result.active) {
    background: var(--surface);
  }

  .search-results :global(.search-result:hover) {
    text-decoration: none;
  }

  .search-results :global(.search-result-title) {
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .search-results :global(.search-result-section) {
    font-size: 0.7rem;
    color: var(--text-secondary);
    opacity: 0.6;
    margin-left: auto;
  }

  .search-results :global(.search-result-desc) {
    width: 100%;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .search-results :global(.search-empty) {
    padding: 24px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
</style>
