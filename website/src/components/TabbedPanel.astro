---
interface Props {
  tabs: Array<{ id: string; label: string }>;
  groupId: string;
}

const { tabs, groupId } = Astro.props;
---

<div class="tabbed-panel" data-tab-group={groupId}>
  <div class="tab-bar">
    {tabs.map((tab, i) => (
      <button
        class:list={['tab-btn', { active: i === 0 }]}
        data-tab-target={tab.id}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <div class="tab-content">
    <slot />
  </div>
</div>

<style>
  .tabbed-panel {
    border-radius: var(--radius);
    overflow: hidden;
  }

  .tab-bar {
    display: flex;
    gap: 0;
    background: #161b22;
    border: 1px solid #30363d;
    border-bottom: none;
    border-radius: var(--radius) var(--radius) 0 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .tab-bar::-webkit-scrollbar {
    display: none;
  }

  .tab-btn {
    position: relative;
    background: none;
    border: none;
    color: #8b949e;
    padding: 10px 16px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    cursor: pointer;
    transition: color 0.15s ease;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.15s ease;
  }

  .tab-btn:hover {
    color: #c9d1d9;
  }

  .tab-btn.active {
    color: #e6edf3;
  }

  .tab-btn.active::after {
    background: var(--accent);
  }

  .tab-content :global([data-tab-id]) {
    display: none;
  }

  .tab-content :global([data-tab-id].active) {
    display: block;
  }
</style>

<script>
  document.querySelectorAll('[data-tab-group]').forEach(group => {
    const buttons = group.querySelectorAll('.tab-btn');
    const panels = group.querySelectorAll('[data-tab-id]');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLElement).dataset.tabTarget;
        buttons.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        group.querySelector(`[data-tab-id="${target}"]`)?.classList.add('active');
      });
    });
  });
</script>
