---
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = posts[0];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

{latest && (
  <section id="whats-new">
    <div class="container reveal">
      <a href={`${base}/blog/${latest.id}/`} class="whatsnew-strip">
        <span class="whatsnew-tag">New</span>
        <span class="whatsnew-title">{latest.data.title}</span>
        <span class="whatsnew-date">{formatDate(latest.data.date)}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
)}

<style>
  section {
    padding: 0 24px 40px;
  }

  .container {
    max-width: 880px;
    margin: 0 auto;
  }

  .whatsnew-strip {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.15s;
    justify-content: center;
  }

  .whatsnew-strip:hover {
    color: var(--text);
    text-decoration: none;
  }

  .whatsnew-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .whatsnew-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .whatsnew-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    opacity: 0.5;
  }

  .whatsnew-strip svg {
    opacity: 0.4;
    transition: transform 0.15s, opacity 0.15s;
  }

  .whatsnew-strip:hover svg {
    transform: translateX(3px);
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .whatsnew-date {
      display: none;
    }
  }
</style>
