---
import TerminalWindow from '../../components/TerminalWindow.astro';
import TabbedPanel from '../../components/TabbedPanel.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- ── Overview ─────────────────────────── -->
<section id="overview">
  <span class="doc-badge">Command Reference</span>
  <h1>vulnex kev</h1>
  <p class="doc-lead">
    Query the <a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog" target="_blank" rel="noopener">CISA Known Exploited Vulnerabilities</a>
    catalog to identify CVEs that are actively being exploited in the wild. Federal agencies are required to remediate
    KEV entries by their due date, making this a critical prioritization signal.
  </p>
</section>

<hr class="doc-divider" />

<!-- ── kev list ──────────────────────────── -->
<section id="kev-list">
  <h2><span class="subcmd-badge">kev list</span></h2>
  <p>Browse all entries in the CISA KEV catalog. Defaults to 20 entries per page with <code>--limit</code> and <code>--offset</code> for pagination. Use <code>--ransomware</code> to filter to entries linked to known ransomware campaigns.</p>

  <h3>Usage</h3>
  <div class="code-inline"><code>vulnex kev list [flags]</code></div>

  <h3>Examples</h3>
  <TabbedPanel groupId="kev-list-examples" tabs={[
    { id: "list-default", label: "Default" },
    { id: "list-page", label: "Pagination" },
    { id: "list-ransomware", label: "Ransomware filter" },
  ]}>
    <div data-tab-id="list-default" class="active">
      <TerminalWindow title="kev list — default (20 entries)">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span>

<span class="t-dim">Showing 20 of 1189 entries</span>

<span class="t-label">CVE ID</span>             <span class="t-label">VENDOR</span>           <span class="t-label">PRODUCT</span>                  <span class="t-label">ADDED</span>        <span class="t-label">RANSOMWARE</span>
<span class="t-cve">CVE-2021-27104</span>     Accellion        FTA                      2021-11-03   Unknown
<span class="t-cve">CVE-2021-27102</span>     Accellion        FTA                      2021-11-03   Unknown
<span class="t-cve">CVE-2021-27101</span>     Accellion        FTA                      2021-11-03   Known
<span class="t-dim">... 17 more rows</span></pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="list-page">
      <TerminalWindow title="kev list — pagination">
        <pre><span class="t-dim"># Page 2</span>
<span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--offset 20 --limit 20</span>

<span class="t-dim"># All entries</span>
<span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--limit 0</span></pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="list-ransomware">
      <TerminalWindow title="kev list — ransomware filter">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--ransomware</span>

<span class="t-dim">Showing 20 of 238 entries</span>

<span class="t-label">CVE ID</span>             <span class="t-label">VENDOR</span>           <span class="t-label">PRODUCT</span>                  <span class="t-label">ADDED</span>        <span class="t-label">RANSOMWARE</span>
<span class="t-cve">CVE-2021-27101</span>     Accellion        FTA                      2021-11-03   Known
<span class="t-cve">CVE-2021-27103</span>     Accellion        FTA                      2021-11-03   Known
<span class="t-dim">...</span></pre>
      </TerminalWindow>
    </div>
  </TabbedPanel>

  <h3>Flags</h3>
  <div class="flags-table">
    <table>
      <thead><tr><th>Flag</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td><code>--limit</code></td><td>int</td><td>20</td><td>Maximum entries to display (0 = all)</td></tr>
        <tr><td><code>--offset</code></td><td>int</td><td>0</td><td>Skip first N entries for pagination</td></tr>
        <tr><td><code>--ransomware</code></td><td>bool</td><td>false</td><td>Show only entries with known ransomware campaigns</td></tr>
      </tbody>
    </table>
  </div>

  <p class="doc-note">Pagination applies only to table output. Structured formats (<code>json</code>, <code>csv</code>) return all entries (respecting <code>--ransomware</code> filter).</p>
</section>

<hr class="doc-divider" />

<!-- ── kev recent ────────────────────────── -->
<section id="kev-recent">
  <h2><span class="subcmd-badge">kev recent</span></h2>
  <p>Show KEV entries added in the last N days. Useful for tracking new additions to the catalog.</p>

  <h3>Usage</h3>
  <div class="code-inline"><code>vulnex kev recent [flags]</code></div>

  <h3>Examples</h3>
  <TabbedPanel groupId="kev-recent-examples" tabs={[
    { id: "recent-7days", label: "Last 7 days" },
    { id: "recent-30ransomware", label: "30 days + ransomware" },
  ]}>
    <div data-tab-id="recent-7days" class="active">
      <TerminalWindow title="kev recent — last 7 days">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev recent</span>

<span class="t-label">CVE ID</span>             <span class="t-label">VENDOR</span>           <span class="t-label">PRODUCT</span>                  <span class="t-label">ADDED</span>        <span class="t-label">RANSOMWARE</span>
<span class="t-cve">CVE-2025-1234</span>      Fortinet         FortiOS                  2026-03-03   Unknown
<span class="t-cve">CVE-2025-5678</span>      Microsoft        Exchange Server          2026-03-01   Known</pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="recent-30ransomware">
      <TerminalWindow title="kev recent — 30 days, ransomware only">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev recent</span> <span class="t-flag">--days 30 --ransomware</span></pre>
      </TerminalWindow>
    </div>
  </TabbedPanel>

  <h3>Flags</h3>
  <div class="flags-table">
    <table>
      <thead><tr><th>Flag</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td><code>--days</code></td><td>int</td><td>7</td><td>Number of days to look back</td></tr>
        <tr><td><code>--ransomware</code></td><td>bool</td><td>false</td><td>Show only entries with known ransomware campaigns</td></tr>
      </tbody>
    </table>
  </div>
</section>

<hr class="doc-divider" />

<!-- ── kev check ─────────────────────────── -->
<section id="kev-check">
  <h2><span class="subcmd-badge">kev check</span></h2>
  <p>Check whether one or more CVEs are in the CISA KEV catalog. Displays detailed label-value output for each match, including vendor, product, description, required action, ransomware status, and notes.</p>

  <h3>Usage</h3>
  <div class="code-inline"><code>vulnex kev check &lt;CVE-ID...&gt; [flags]</code></div>

  <h3>Examples</h3>
  <TabbedPanel groupId="kev-check-examples" tabs={[
    { id: "check-single", label: "Single CVE" },
    { id: "check-full", label: "Full output" },
    { id: "check-multi", label: "Multiple + stdin" },
  ]}>
    <div data-tab-id="check-single" class="active">
      <TerminalWindow title="kev check — single CVE">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev check</span> <span class="t-cve">CVE-2021-44228</span>

<span class="t-label">CVE ID:</span>           <span class="t-cve">CVE-2021-44228</span>
<span class="t-label">Name:</span>             Apache Log4j2 Remote Code Execution Vulnerability
<span class="t-label">Vendor:</span>           Apache
<span class="t-label">Product:</span>          Log4j2
<span class="t-label">Description:</span>      Apache Log4j2 2.0-beta9 through 2.15.0 JNDI features used in confi...
<span class="t-label">Date Added:</span>       2021-12-10
<span class="t-label">Due Date:</span>         2021-12-24
<span class="t-label">Required Action:</span>  For all affected software assets, apply patches referenced in CISA...
<span class="t-label">Ransomware:</span>       <span class="t-critical">Known</span>
<span class="t-label">Notes:</span>            https://logging.apache.org/log4j/2.x/security.html</pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="check-full">
      <TerminalWindow title="kev check — full output">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev check</span> <span class="t-cve">CVE-2021-44228</span> <span class="t-flag">--long</span></pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="check-multi">
      <TerminalWindow title="kev check — multiple CVEs + stdin">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev check</span> <span class="t-cve">CVE-2024-3094 CVE-2023-44228</span>

<span class="t-prompt">$</span> echo <span class="t-cve">"CVE-2024-3094"</span> | <span class="t-cmd">vulnex kev check</span> <span class="t-flag">--stdin</span></pre>
      </TerminalWindow>
    </div>
  </TabbedPanel>

  <h3>Flags</h3>
  <div class="flags-table">
    <table>
      <thead><tr><th>Flag</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td><code>--stdin</code></td><td>bool</td><td>false</td><td>Read CVE IDs from stdin (one per line)</td></tr>
        <tr><td><code>-l, --long</code></td><td>bool</td><td>false</td><td>Show full content for description, required action, and notes (otherwise truncated to 80 chars)</td></tr>
      </tbody>
    </table>
  </div>

  <p class="doc-note">CVEs not found in KEV are reported on stderr. Use <code>-q</code> to suppress these messages.</p>
</section>

<hr class="doc-divider" />

<!-- ── kev stats ─────────────────────────── -->
<section id="kev-stats">
  <h2><span class="subcmd-badge">kev stats</span></h2>
  <p>Display summary statistics for the KEV catalog: total entries, ransomware-linked count, top vendors, and recent additions.</p>

  <h3>Usage</h3>
  <div class="code-inline"><code>vulnex kev stats [flags]</code></div>

  <h3>Examples</h3>
  <TabbedPanel groupId="kev-stats-examples" tabs={[
    { id: "stats-default", label: "Default stats" },
    { id: "stats-vendors", label: "More vendors" },
  ]}>
    <div data-tab-id="stats-default" class="active">
      <TerminalWindow title="kev stats">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev stats</span>

<span class="t-label">KEV Catalog Statistics</span>

<span class="t-label">Total Entries</span>       1,189
<span class="t-label">Ransomware</span>          238
<span class="t-label">Last Updated</span>        2026-03-05

<span class="t-label">Top Vendors</span>
Microsoft           305
Cisco               68
Apple               65
Adobe               64
Google              53
Oracle              40
Apache              36
Fortinet            22
VMware              21
Citrix              18</pre>
      </TerminalWindow>
    </div>
    <div data-tab-id="stats-vendors">
      <TerminalWindow title="kev stats — more vendors">
        <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev stats</span> <span class="t-flag">--top 20</span></pre>
      </TerminalWindow>
    </div>
  </TabbedPanel>

  <h3>Flags</h3>
  <div class="flags-table">
    <table>
      <thead><tr><th>Flag</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
      <tbody>
        <tr><td><code>--top</code></td><td>int</td><td>10</td><td>Number of top vendors to display</td></tr>
      </tbody>
    </table>
  </div>
</section>

<hr class="doc-divider" />

<!-- ── What is CISA KEV? ────────────────── -->
<section id="what-is-kev">
  <h2>What is CISA KEV?</h2>
  <p>
    The <strong>Known Exploited Vulnerabilities (KEV) catalog</strong> is maintained by the
    <a href="https://www.cisa.gov/" target="_blank" rel="noopener">Cybersecurity and Infrastructure Security Agency (CISA)</a>.
    It lists CVEs that are confirmed to be actively exploited in the wild.
  </p>

  <div class="info-cards">
    <div class="info-card">
      <h4>Mandatory remediation</h4>
      <p>Federal agencies are required by <a href="https://www.cisa.gov/news-events/directives/bod-22-01-reducing-significant-risk-known-exploited-vulnerabilities" target="_blank" rel="noopener">BOD 22-01</a> to remediate KEV entries by their due date. Many private organizations also use KEV as a prioritization signal.</p>
    </div>
    <div class="info-card">
      <h4>Ransomware tracking</h4>
      <p>Each KEV entry includes a <code>KnownRansomwareCampaign</code> field indicating whether the vulnerability has been used in ransomware attacks. Use <code>--ransomware</code> to filter for these entries.</p>
    </div>
  </div>

  <h3>Why KEV matters for prioritization</h3>
  <p>
    A CVE in the KEV catalog is <em>confirmed actively exploited</em> &mdash; not just theoretically exploitable.
    In vulnex's <a href={`${base}/docs/scoring/`}>composite scoring</a>, KEV presence is one of three signals
    (alongside CVSS and EPSS) and automatically triggers a <strong>P0-CRITICAL</strong> priority rating.
  </p>
</section>

<hr class="doc-divider" />

<!-- ── Tips & Recipes ───────────────────── -->
<section id="tips">
  <h2>Tips &amp; recipes</h2>

  <h3>Find ransomware-linked CVEs and enrich them</h3>
  <TerminalWindow>
    <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--ransomware --limit 0 -o csv</span> \
  | cut -d, -f1 \
  | <span class="t-cmd">vulnex cve get</span> <span class="t-flag">--stdin -o json</span></pre>
  </TerminalWindow>

  <h3>Check recent KEV additions and enrich</h3>
  <TerminalWindow>
    <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev recent</span> <span class="t-flag">--days 7 -o csv</span> \
  | cut -d, -f1 \
  | <span class="t-cmd">vulnex cve get</span> <span class="t-flag">--stdin</span></pre>
  </TerminalWindow>

  <h3>Page through the catalog</h3>
  <TerminalWindow>
    <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--limit 20</span>              <span class="t-dim"># page 1</span>
<span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--limit 20 --offset 20</span>  <span class="t-dim"># page 2</span>
<span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--limit 20 --offset 40</span>  <span class="t-dim"># page 3</span></pre>
  </TerminalWindow>

  <h3>Export KEV data</h3>
  <TerminalWindow>
    <pre><span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--limit 0 -o json</span> > kev-catalog.json
<span class="t-prompt">$</span> <span class="t-cmd">vulnex kev list</span> <span class="t-flag">--ransomware --limit 0 -o csv</span> > ransomware-cves.csv</pre>
  </TerminalWindow>
</section>

