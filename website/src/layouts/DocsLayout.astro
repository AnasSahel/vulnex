---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import { getDocsSections, getPagerLinks } from '../content/docs-helpers';
import '../styles/docs-page.css';

interface Props {
  title: string;
  description: string;
  slug?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, description, slug } = Astro.props;
const pager = slug ? await getPagerLinks(slug) : { prev: undefined, next: undefined };

// Determine which section this page belongs to for breadcrumbs
const docsSections = await getDocsSections();
const currentSection = slug ? docsSections.find(s => s.pages.some(p => p.slug === slug)) : undefined;

// Get subcommands for right sidebar TOC
const currentPage = slug ? docsSections.flatMap(s => s.pages).find(p => p.slug === slug) : undefined;
const subcommands = currentPage?.subcommands ?? [];
---

<BaseLayout title={title} description={description}>
  <Navbar />
  <div class="docs-page">
    <aside class="docs-sidebar" id="docs-sidebar">
      <DocsSidebar slug={slug} />
    </aside>
    <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
    </button>
    <main class="docs-content">
      {slug && (
        <nav class="breadcrumbs" aria-label="Breadcrumbs">
          <a href={`${base}/docs/`}>Docs</a>
          {currentSection && <span class="breadcrumb-sep">/</span>}
          {currentSection && <span class="breadcrumb-current">{currentSection.label}</span>}
        </nav>
      )}
      <slot />
      {(pager.prev || pager.next) && (
        <nav class="docs-pager" aria-label="Page navigation">
          {pager.prev ? (
            <a href={`${base}/docs/${pager.prev.slug}/`} class="pager-link pager-prev">
              <span class="pager-dir">&larr; Previous</span>
              <span class="pager-title">{pager.prev.title}</span>
            </a>
          ) : <span />}
          {pager.next ? (
            <a href={`${base}/docs/${pager.next.slug}/`} class="pager-link pager-next">
              <span class="pager-dir">Next &rarr;</span>
              <span class="pager-title">{pager.next.title}</span>
            </a>
          ) : <span />}
        </nav>
      )}
    </main>
    {subcommands.length > 0 && (
      <aside class="docs-toc" id="docs-toc">
        <span class="toc-label">On this page</span>
        <ul>
          <li><a href="#overview" class="toc-link toc-top">Overview</a></li>
          {subcommands.map(sub => (
            <li>
              <a href={`#${sub.id}`} class="toc-link" data-toc-id={sub.id}>{sub.label}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
  <Footer />
</BaseLayout>

<style>
  .docs-page {
    display: flex;
    padding-top: 60px;
    min-height: 100vh;
    position: relative;
  }

  .docs-sidebar {
    position: sticky;
    top: 60px;
    width: 260px;
    flex-shrink: 0;
    height: calc(100vh - 60px);
    overflow-y: auto;
    padding: 24px 16px 32px;
    border-right: 1px solid var(--border);
  }

  .sidebar-toggle {
    display: none;
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 90;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }

  .docs-content {
    flex: 1;
    min-width: 0;
    max-width: 900px;
    padding: 40px 56px 80px;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    margin-bottom: 24px;
  }

  .breadcrumbs a {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumbs a:hover {
    text-decoration: underline;
  }

  .breadcrumb-sep {
    color: var(--text-secondary);
  }

  .breadcrumb-current {
    color: var(--text-secondary);
  }

  /* Prev/Next Pager */
  .docs-pager {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s;
    min-width: 0;
  }

  .pager-link:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .pager-next {
    margin-left: auto;
    text-align: right;
  }

  .pager-dir {
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .pager-title {
    font-weight: 600;
    font-size: 0.9rem;
  }

  /* Right TOC sidebar */
  .docs-toc {
    position: sticky;
    top: 84px;
    width: 200px;
    flex-shrink: 0;
    height: fit-content;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 0 16px 32px 0;
  }

  .toc-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: 10px;
    padding-left: 12px;
  }

  .docs-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--border);
  }

  .toc-link {
    display: block;
    padding: 4px 12px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    border-left: 2px solid transparent;
    margin-left: -1px;
  }

  .toc-link:hover {
    color: var(--accent);
    border-left-color: var(--accent);
    text-decoration: none;
  }

  .toc-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .docs-sidebar {
      display: none;
      position: fixed;
      top: 60px;
      left: 0;
      bottom: 0;
      z-index: 80;
      background: var(--bg);
      border-right: 1px solid var(--border);
      width: 260px;
    }

    .docs-sidebar.open {
      display: block;
    }

    .sidebar-toggle {
      display: flex;
    }

    .docs-toc {
      display: none;
    }

    .docs-content {
      padding: 32px 20px 64px;
    }

    .docs-pager {
      flex-direction: column;
    }

    .pager-next {
      text-align: left;
    }
  }
</style>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');

  // Scroll-spy for right TOC
  const tocLinks = document.querySelectorAll('.toc-link[data-toc-id]');
  if (tocLinks.length > 0) {
    const tocIds = Array.from(tocLinks).map(l => (l as HTMLElement).dataset.tocId!);
    const sections = tocIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];

    const tocObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            const active = document.querySelector(`.toc-link[data-toc-id="${entry.target.id}"]`);
            if (active) active.classList.add('active');
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    sections.forEach(s => tocObserver.observe(s));
  }

  if (toggle && sidebar) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('open');
    });

    // Close sidebar when clicking a link (mobile)
    sidebar.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        sidebar.classList.remove('open');
      });
    });
  }
</script>
