---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageBackground from '../../components/PageBackground.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Blog — vulnex" description="News, feature deep-dives, and threat intelligence insights from the vulnex project.">
  <PageBackground />
  <Navbar />
  <main class="blog">
    <div class="blog-inner">
      <header class="blog-header">
        <h1>Blog</h1>
        <p>Feature deep-dives, release notes, and threat intelligence insights.</p>
      </header>

      <div class="post-list">
        {posts.map((post, i) => (
          <a href={`${base}/blog/${post.id}/`} class="post-row">
            <div class="post-row-left">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
              {i === 0 && <span class="new-tag">New</span>}
            </div>
            <div class="post-row-main">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <svg class="post-row-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog {
    padding-top: 140px;
    padding-bottom: 100px;
    min-height: 100vh;
  }

  .blog-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .blog-header {
    margin-bottom: 56px;
  }

  .blog-header h1 {
    font-size: 3.5rem;
    font-weight: 800;
    letter-spacing: -0.045em;
    line-height: 1;
    margin-bottom: 16px;
  }

  .blog-header p {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  /* ── Post list ───────────────────────── */

  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-row {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 28px 0;
    border-top: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.15s;
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-row:hover {
    text-decoration: none;
    opacity: 0.7;
  }

  .post-row-left {
    flex-shrink: 0;
    width: 100px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .post-row-left time {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  .new-tag {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    width: fit-content;
  }

  .post-row-main {
    flex: 1;
    min-width: 0;
  }

  .post-row-main h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .post-row-main p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-row-arrow {
    flex-shrink: 0;
    color: var(--text-secondary);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    margin-top: 4px;
  }

  .post-row:hover .post-row-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  @media (max-width: 600px) {
    .blog {
      padding-top: 100px;
    }

    .blog-header h1 {
      font-size: 2.5rem;
    }

    .post-row {
      flex-wrap: wrap;
      gap: 4px;
      padding: 20px 0;
    }

    .post-row-left {
      width: 100%;
      flex-direction: row;
      align-items: center;
      gap: 10px;
    }

    .post-row-arrow {
      display: none;
    }
  }
</style>
