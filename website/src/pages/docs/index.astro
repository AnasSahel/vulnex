---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { docsSections } from '../../content/docs-nav';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<DocsLayout
  title="Documentation — vulnex"
  description="Browse vulnex documentation: getting started guides, command references, scoring model, and CI/CD integration."
>
  <div class="hub-header">
    <span class="hub-badge">Documentation</span>
    <h1>vulnex docs</h1>
    <p class="hub-lead">
      Learn how to use vulnex for vulnerability intelligence, risk scoring,
      and CI/CD pipeline gating.
    </p>
  </div>

  <div class="hub-quick">
    <a href={`${base}/docs/getting-started/`} class="quick-start-card">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
      <div>
        <strong>Quick Start</strong>
        <span>Install and run your first query in under two minutes</span>
      </div>
      <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <div class="section-grid">
    {docsSections.map(section => (
      <div class="section-card">
        <div class="section-card-header">
          <span class="section-icon" set:html={section.icon} />
          <h2>{section.label}</h2>
        </div>
        <ul>
          {section.pages.map(page => (
            <li>
              <a href={`${base}/docs/${page.slug}/`}>
                <strong>{page.title}</strong>
                <span>{page.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</DocsLayout>

<style>
  .hub-header {
    margin-bottom: 48px;
  }

  .hub-badge {
    display: inline-block;
    padding: 4px 14px;
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .hub-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .hub-lead {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 520px;
    line-height: 1.7;
  }

  /* Quick start card */
  .hub-quick {
    margin-bottom: 48px;
  }

  .quick-start-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, background 0.15s;
  }

  .quick-start-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .quick-start-card svg:first-child {
    color: var(--accent);
    flex-shrink: 0;
  }

  .quick-start-card div {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .quick-start-card strong {
    font-size: 1rem;
  }

  .quick-start-card span {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .quick-start-card .arrow {
    color: var(--text-secondary);
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  .quick-start-card:hover .arrow {
    transform: translateX(4px);
  }

  /* Section grid */
  .section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }

  .section-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .section-icon {
    color: var(--accent);
    display: flex;
  }

  .section-card h2 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .section-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-card li a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.15s;
  }

  .section-card li a:hover {
    background: var(--bg);
    text-decoration: none;
  }

  .section-card li a strong {
    font-size: 0.9rem;
  }

  .section-card li a span {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .hub-header h1 {
      font-size: 1.75rem;
    }

    .section-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
