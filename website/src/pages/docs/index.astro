---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getDocsSections } from '../../content/docs-helpers';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const docsSections = await getDocsSections();
---

<DocsLayout
  title="Documentation — vulnex"
  description="Browse vulnex documentation: getting started guides, command references, scoring model, and CI/CD integration."
>
  <div class="hub-header">
    <span class="hub-badge">Documentation</span>
    <h1>vulnex docs</h1>
  </div>

  <!-- Introduction -->
  <section class="intro">
    <h2>What is vulnex?</h2>
    <p>
      <strong>vulnex</strong> is an open-source, offline-capable CLI that aggregates vulnerability data from five authoritative sources into a single, enriched view. It gives security teams and developers a fast way to look up CVEs, score risk, scan SBOMs and lockfiles, and gate CI/CD pipelines &mdash; all from the terminal.
    </p>

    <h3>Pain points it solves</h3>
    <ul class="pain-list">
      <li><strong>Fragmented vulnerability data.</strong> NVD, CISA KEV, EPSS, GitHub Advisories, and OSV each live in separate databases with different APIs. vulnex queries them in parallel and merges the results.</li>
      <li><strong>No risk context in raw CVE data.</strong> A CVSS score alone doesn't tell you if a vulnerability is actively exploited or likely to be. vulnex combines CVSS, EPSS probability, and KEV status into a composite P0&ndash;P4 priority score.</li>
      <li><strong>Manual SBOM triage.</strong> Build tools generate SBOMs but don't tell you which components are vulnerable. vulnex scans CycloneDX/SPDX SBOMs and nine lockfile formats, then enriches every finding.</li>
      <li><strong>No CI gate for new vulnerabilities.</strong> <code>sbom diff</code> compares two SBOMs and exits non-zero only when <em>new</em> vulnerabilities appear &mdash; so you gate on regressions, not pre-existing debt.</li>
      <li><strong>Online-only tooling.</strong> vulnex caches everything in a local SQLite database with configurable TTLs, so you can work offline or in air-gapped environments.</li>
    </ul>
  </section>

  <!-- Architecture Diagram -->
  <section class="diagram-section">
    <h2>How it works</h2>
    <p>vulnex fetches from all five sources in parallel, merges and correlates the data, computes a risk score, and outputs in your chosen format.</p>
    <div class="diagram-wrap">
      <img src={`${base}/images/vulnex-architecture.svg`} alt="vulnex architecture diagram showing data flow from NVD, KEV, EPSS, GHSA, and OSV through vulnex processing to multiple output formats" width="1100" height="720" loading="lazy" />
    </div>
  </section>

  <hr class="hub-divider" />

  <!-- Quick Start -->
  <div class="hub-quick">
    <a href={`${base}/docs/getting-started/`} class="quick-start-card">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
      <div>
        <strong>Quick Start</strong>
        <span>Install and run your first query in under two minutes</span>
      </div>
      <svg class="arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Section Grid -->
  <div class="section-grid">
    {docsSections.map(section => (
      <div class="section-card">
        <div class="section-card-header">
          <span class="section-icon" set:html={section.icon} />
          <h2>{section.label}</h2>
        </div>
        <ul>
          {section.pages.map(page => (
            <li>
              <a href={`${base}/docs/${page.slug}/`}>
                <strong>{page.title}</strong>
                <span>{page.description}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</DocsLayout>

<style>
  .hub-header {
    margin-bottom: 32px;
  }

  .hub-badge {
    display: inline-block;
    padding: 4px 14px;
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .hub-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0;
    letter-spacing: -0.02em;
  }

  /* Introduction */
  .intro {
    margin-bottom: 40px;
  }

  .intro h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .intro h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 24px;
    margin-bottom: 12px;
  }

  .intro p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 680px;
  }

  .intro code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 2px 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .pain-list {
    padding-left: 20px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pain-list li {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .pain-list li strong {
    color: var(--text);
  }

  /* Diagram */
  .diagram-section {
    margin-bottom: 40px;
  }

  .diagram-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .diagram-section p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 20px;
    max-width: 680px;
  }

  .diagram-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    background: var(--surface);
    overflow-x: auto;
  }

  .diagram-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  .hub-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 40px 0;
  }

  /* Quick start card */
  .hub-quick {
    margin-bottom: 40px;
  }

  .quick-start-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s;
  }

  .quick-start-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .quick-start-card svg:first-child {
    color: var(--accent);
    flex-shrink: 0;
  }

  .quick-start-card div {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .quick-start-card strong {
    font-size: 1rem;
  }

  .quick-start-card span {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .quick-start-card .arrow {
    color: var(--text-secondary);
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  .quick-start-card:hover .arrow {
    transform: translateX(4px);
  }

  /* Section grid */
  .section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }

  .section-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .section-icon {
    color: var(--accent);
    display: flex;
  }

  .section-card h2 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0;
  }

  .section-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .section-card li a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.15s;
  }

  .section-card li a:hover {
    background: var(--bg);
    text-decoration: none;
  }

  .section-card li a strong {
    font-size: 0.9rem;
  }

  .section-card li a span {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .hub-header h1 {
      font-size: 1.75rem;
    }

    .section-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
