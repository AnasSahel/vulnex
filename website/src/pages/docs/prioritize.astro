    margin-bottom: 8px;
  }

  .pain-points li:last-child {
    margin-bottom: 0;
  }

  /* ── Priority table ──────────────────────── */

  .priority-table {
    overflow-x: auto;
    margin: 20px 0 24px;
  }

  .priority-p0 {
    color: var(--red, #ef4444);
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .priority-p1 {
    color: var(--orange, #f97316);
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .priority-p2 {
    color: var(--yellow, #eab308);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .priority-p3 {
    color: var(--text-secondary);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .priority-p4 {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  /* ── Comparison table ───────────────────── */

  .comparison-table {
    overflow-x: auto;
    margin: 20px 0 24px;
  }

  .comparison-table table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .comparison-table thead {
