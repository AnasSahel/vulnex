---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ShowcaseSection from '../components/ShowcaseSection.astro';
import PlatformSection from '../components/PlatformSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import InstallSection from '../components/InstallSection.astro';
import CiCdSection from '../components/CiCdSection.astro';
import WhatsNew from '../components/WhatsNew.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="vulnex — Vulnerability intelligence from your terminal"
  description="Open-source CLI and cloud platform that aggregates NVD, CISA KEV, EPSS, GitHub Advisory, and OSV data into a single enriched view with configurable risk scoring, lockfile scanning, and SBOM analysis."
>
  <Navbar />
  <main>
    <Hero />
    <ShowcaseSection />
    <PlatformSection />
    <FeaturesSection />
    <InstallSection />
    <CiCdSection />
    <WhatsNew />
  </main>
  <Footer />
</BaseLayout>
